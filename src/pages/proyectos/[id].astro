---
import Layout from '../../layouts/Layout.astro';
import { projects, type Project } from '../../data/projects';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

interface Props {
  project: Project;
}

const { project } = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const mediaSrc = (media: Project['thumb'] | Project['modalEmbed']) =>
  media.type === 'video' ? `${base}${media.src}` : media.src;
---

<Layout title={`${project.title} — Sequor`} activePage={null}>
  <article class="mx-auto max-w-4xl px-6 pt-24 pb-20">
    <a href={base} class="mb-6 inline-block text-sm text-neutral-500 hover:text-neutral-900">
      &larr; Volver
    </a>

    {project.modalEmbed.type === 'video' ? (
      <video
        src={mediaSrc(project.modalEmbed)}
        controls
        class="aspect-video w-full rounded-lg border-0 bg-neutral-100"
      />
    ) : (
      <iframe
        src={project.modalEmbed.src}
        title={project.title}
        loading="lazy"
        allow="autoplay"
        class="aspect-video w-full rounded-lg border-0 bg-neutral-100"
      />
    )}

    <h1 class="mt-8 text-3xl font-bold">{project.title}</h1>
    <p class="mt-1 text-xs tracking-wide text-neutral-500 uppercase">{project.category}</p>
    <p class="mt-4 text-neutral-700">{project.description}</p>
  </article>
</Layout>
