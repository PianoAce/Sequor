---
import Layout from '../layouts/Layout.astro';
import { projects, type Project } from '../data/projects';

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const mediaSrc = (media: Project['thumb']) =>
  media.type === 'video' ? `${base}${media.src}` : media.src;
---

<Layout title="Sequor — Edicion de video y motion graphics" activePage="inicio">
  <section class="px-6 pt-12 pb-12 text-center">
    <h1 class="text-center font-bold text-7xl leading-[1.1]">
      Edición de video y motion graphics</h1>
  </section>

  <section class="mx-auto grid max-w-350 grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-6 px-6 pb-20">
    {projects.map((project) => (
      <a
        href={`${base}proyectos/${project.id}`}
        data-category={project.category}
        class="project-card group relative block cursor-pointer"
      >
        {project.thumb.type === 'video' ? (
          <video
            src={mediaSrc(project.thumb)}
            muted
            loop
            playsinline
            transition:name={`video-${project.id}`}
            class="pointer-events-none aspect-video w-full border-0 bg-neutral-100"
          />
        ) : (
          <iframe
            src={project.thumb.src}
            title={project.title}
            loading="lazy"
            allow="autoplay"
            transition:name={`video-${project.id}`}
            class="pointer-events-none aspect-video w-full border-0 bg-neutral-100"
          />
        )}
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center bg-black/70 opacity-0 transition-opacity duration-300 group-hover:opacity-100 group-focus-visible:opacity-100">
          <span class="px-4 text-center text-sm font-semibold text-white">{project.title}</span>
        </div>
      </a>
    ))}
  </section>

  <script>
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-filter]');
    const cards = document.querySelectorAll<HTMLAnchorElement>('.project-card');
    const thumbVideos = document.querySelectorAll<HTMLVideoElement>('.project-card video');

    if (thumbVideos.length) {
      const playbackObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            const video = entry.target as HTMLVideoElement;
            if (entry.isIntersecting) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          });
        },
        { rootMargin: '200px' },
      );

      thumbVideos.forEach((video) => playbackObserver.observe(video));
    }

    filterButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterButtons.forEach((b) => b.setAttribute('aria-pressed', 'false'));
        btn.setAttribute('aria-pressed', 'true');

        const filter = btn.dataset.filter;
        cards.forEach((card) => {
          card.hidden = filter !== 'all' && card.dataset.category !== filter;
        });
      });
    });
  </script>
</Layout>
