---
import { Clapperboard, ChevronDown } from 'lucide-astro';
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="Sequor — Edicion de video y motion graphics" activePage="inicio" hideLogoUntilScroll>
  <section id="hero" class="relative flex h-[calc(100vh-4.5rem)] flex-col items-center justify-center gap-6 px-6 text-center">
    <div class="flex items-center gap-4">
      <Clapperboard class="h-12 w-12 sm:h-16 sm:w-16" />
      <span class="text-6xl font-bold tracking-widest sm:text-8xl">Sequor</span>
    </div>
    <p class="text-lg text-white/70 sm:text-xl">Edición de video y motion graphics</p>

    <a
      href="#contenido"
      id="scroll-hint"
      aria-label="Bajar para ver los proyectos"
      class="absolute bottom-10 animate-bounce text-white/60 transition-colors duration-300 hover:text-white"
    >
      <ChevronDown class="h-8 w-8" />
    </a>
  </section>

  <div id="hero-end-sentinel" class="h-px"></div>

  <section id="contenido" class="mx-auto grid max-w-350 grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-6 px-6 pt-16 pb-20">
    {projects.map((project) => <ProjectCard project={project} />)}
  </section>

  <script>
    // Se vuelve a correr en cada navegación (astro:page-load), no solo en
    // la primera carga: al volver a esta página desde /proyectos/<id> vía
    // View Transitions, el grid es DOM nuevo — sin esto, los videos
    // quedaban sin ningún IntersectionObserver mirándolos y se veían
    // "congelados" en vez de seguir en loop.
    function setupHome() {
      const thumbVideos = document.querySelectorAll<HTMLVideoElement>('.project-card video');

      if (thumbVideos.length) {
        const playbackObserver = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              const video = entry.target as HTMLVideoElement;
              if (entry.isIntersecting) {
                video.play().catch(() => {});
              } else {
                video.pause();
              }
            });
          },
          { rootMargin: '200px' },
        );

        thumbVideos.forEach((video) => playbackObserver.observe(video));
      }

      // Revela el logo del nav (invisible por defecto en esta página, ver
      // hideLogoUntilScroll en Layout.astro) justo cuando el "Sequor"
      // grande del hero desaparece de la vista. Mismo truco que ya usamos
      // para el header completo, ahora acotado solo al logo — los links
      // de Inicio/Sobre mí/Contacto no se tocan, se quedan siempre visibles.
      const logoLink = document.getElementById('nav-logo-link');
      const heroEndSentinel = document.getElementById('hero-end-sentinel');

      if (logoLink && heroEndSentinel) {
        const logoRevealObserver = new IntersectionObserver(
          ([entry]) => {
            const pastHero = entry.boundingClientRect.top < 0;
            logoLink.classList.toggle('opacity-0', !pastHero);
            logoLink.classList.toggle('pointer-events-none', !pastHero);
            logoLink.classList.toggle('opacity-100', pastHero);
            logoLink.classList.toggle('pointer-events-auto', pastHero);
          },
          { threshold: 0 },
        );

        logoRevealObserver.observe(heroEndSentinel);
      }

      // Scroll suave al hacer clic en la flecha. No dependemos únicamente
      // de "scroll-smooth" en CSS porque el navegador puede desactivarlo
      // (ajuste de accesibilidad "reducir movimiento") y porque, con
      // ClientRouter activo, un <a href="#..."> a veces se trata como
      // navegación en vez de como scroll normal. Haciéndolo a mano con
      // scrollIntoView, funciona siempre igual.
      const scrollHint = document.getElementById('scroll-hint');
      const contenido = document.getElementById('contenido');

      scrollHint?.addEventListener('click', (event) => {
        event.preventDefault();
        contenido?.scrollIntoView({ behavior: 'smooth' });
      });
    }

    document.addEventListener('astro:page-load', setupHome);
  </script>
</Layout>
