---
import { Icon } from 'astro-icon/components';
import { Mail } from 'lucide-astro';
import Layout from '../layouts/Layout.astro';

const links = [
  {
    label: 'Correo',
    href: 'mailto:vocalimprove@gmail.com',
    icon: 'lucide',
  },
  {
    label: 'WhatsApp',
    href: 'http://wa.me/573005524213',
    icon: 'simple-icons:whatsapp',
  },
  {
    label: 'Instagram',
    href: 'https://www.instagram.com/danicoronadomusic',
    icon: 'simple-icons:instagram',
  },
] as const;
---

<Layout title="Contacto — Sequor" activePage="contacto">
  <section class="mx-auto max-w-2xl px-6 pt-24 pb-20 text-center">
    <h1 class="text-3xl font-bold">Contacto</h1>
    <p class="mt-3 text-white/70">Contáctame directamente aquí:</p>

    <div class="mt-10 flex justify-center gap-8">
      {links.map((link) => (
        <a
          href={link.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={link.label}
          class="text-white/70 transition-colors-transform duration-300 hover:text-white hover:scale-125"
        >
          {link.icon === 'lucide' ? (
            <Mail class="h-8 w-8" />
          ) : (
            <Icon name={link.icon} class="h-8 w-8" />
          )}
        </a>
      ))}
    </div>
  </section>
</Layout>
