---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  activePage: 'inicio' | 'sobre-mi' | 'contacto' | null;
  // Si es true, el logo del nav arranca invisible (la página se encarga
  // de revelarlo cuando corresponda — ver hero-end-sentinel en index.astro).
  hideLogoUntilScroll?: boolean;
}

const {
  title,
  description = 'Portafolio de Daniel: edición de video, producción de audio y composición musical.',
  activePage,
  hideLogoUntilScroll = false,
} = Astro.props;

// Garantiza exactamente una barra final, sin importar cómo esté escrito
// el "base" en astro.config.mjs.
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <ClientRouter />
  </head>
  <body class="text-white bg-neutral-800">
    <Header activePage={activePage} hideLogoUntilScroll={hideLogoUntilScroll} />

    <main class="pt-18">
      <slot />
    </main>

    <Footer />

    <script>
      // Esto corre UNA sola vez: escucha en `window`, que nunca se destruye
      // entre transiciones (a diferencia del header o el footer), así que
      // repetirlo en cada astro:page-load solo apilaría listeners duplicados.
      let scrollEndTimer: ReturnType<typeof setTimeout> | undefined;

      window.addEventListener(
        'scroll',
        () => {
          document.documentElement.classList.add('is-scrolling');
          clearTimeout(scrollEndTimer);
          scrollEndTimer = setTimeout(() => {
            document.documentElement.classList.remove('is-scrolling');
          }, 400);
        },
        { passive: true },
      );
    </script>
  </body>
</html>
